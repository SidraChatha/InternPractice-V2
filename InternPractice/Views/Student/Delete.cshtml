@model InternPractice.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">
    <div class="alert alert-danger shadow">
        <h4 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> Are you sure?</h4>
        <p>You are about to permanently delete this student record. This action cannot be undone.</p>
    </div>

    <div class="card shadow-sm border-danger">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Student Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

                <dt class="col-sm-3">Department</dt>
                <dd class="col-sm-9">@(Model.Department?.Name ?? "N/A")</dd>
            </dl>

            <form asp-action="Delete" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>