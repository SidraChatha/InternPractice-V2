@model InternPractice.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Course</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Advanced C# Development" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                            <small class="text-muted">Maximum 150 characters.</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Credits" class="form-label fw-bold"></label>
                                <input asp-for="Credits" class="form-control" type="number" min="1" max="6" />
                                <span asp-validation-for="Credits" class="text-danger"></span>
                                <small class="text-muted">Between 1 and 6.</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="DepartmentId" class="form-label fw-bold">Department</label>
                                <input asp-for="DepartmentId" class="form-control" type="number" />
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                                <small class="text-muted">Enter valid Department ID.</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-lg"></i> Create Course
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}