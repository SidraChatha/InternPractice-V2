@model InternPractice.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Course Information</h4>
                </div>
                <div class="card-body p-4">
                    <dl class="row">
                        <dt class="col-sm-4 text-muted">Title</dt>
                        <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.Title)</dd>

                        <dt class="col-sm-4 text-muted">Credits</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-primary">@Html.DisplayFor(model => model.Credits) Credits</span>
                        </dd>

                        <dt class="col-sm-4 text-muted">Department</dt>
                        <dd class="col-sm-8">@(Model.Department?.Name ?? "N/A")</dd>
                    </dl>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-info text-white px-4">
                            <i class="bi bi-pencil"></i> Edit Course
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>